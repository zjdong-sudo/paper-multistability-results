      RowBox[{"batchData", "=", 
       RowBox[{"Import", "[", 
        RowBox[{"files", "[", 
         RowBox[{"[", "f", "]"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"idx", "=", 
          RowBox[{"batchData", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"gbSet", "=", 
          RowBox[{"batchData", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "4"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"KeyExistsQ", "[", 
             RowBox[{"parent", ",", "idx"}], "]"}]}], ",", 
           RowBox[{
            RowBox[{"parent", "[", "idx", "]"}], "=", "idx"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
          "\:5bf9\:6bcf\:4e2a\:7f6e\:6362\:540e\:7684", " ", "GB", " ", 
           "\:8ba1\:7b97\:54c8\:5e0c\:503c"}], "*)"}], 
         RowBox[{"Do", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"h", "=", 
             RowBox[{"Hash", "[", "gb", "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"KeyExistsQ", "[", 
               RowBox[{"gbMap", ",", "h"}], "]"}], ",", 
              RowBox[{"union", "[", 
               RowBox[{"idx", ",", 
                RowBox[{"gbMap", "[", "h", "]"}]}], "]"}], ",", 
              RowBox[{
               RowBox[{"gbMap", "[", "h", "]"}], "=", "idx"}]}], "]"}], ";"}],
            ",", 
           RowBox[{"{", 
            RowBox[{"gb", ",", "gbSet"}], "}"}]}], "]"}], ";"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "batchData", "]"}]}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Clear", "[", "batchData", "]"}], ";", 
      RowBox[{"(*", "\:53ca\:65f6\:91ca\:653e\:5185\:5b58", "*)"}], 
      RowBox[{"If", "[", 
