    RowBox[{"<|", "|>"}]}], ";"}], " ", 
  RowBox[{"(*", "\:5e76\:67e5\:96c6\:7ed3\:6784", "*)"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"find", "[", "i_", "]"}], ":=", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"KeyExistsQ", "[", 
          RowBox[{"parent", ",", "i"}], "]"}]}], ",", 
        RowBox[{
         RowBox[{"parent", "[", "i", "]"}], "=", "i"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"parent", "[", "i", "]"}], "==", "i"}], ",", "i", ",", 
        RowBox[{
         RowBox[{"parent", "[", "i", "]"}], "=", 
         RowBox[{"find", "[", 
          RowBox[{"parent", "[", "i", "]"}], "]"}]}]}], "]"}]}], ")"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"union", "[", 
     RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"rootI", "=", 
         RowBox[{"find", "[", "i", "]"}]}], ",", 
        RowBox[{"rootJ", "=", 
         RowBox[{"find", "[", "j", "]"}]}]}], "}"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"rootI", "!=", "rootJ"}], ",", 
        RowBox[{
         RowBox[{"parent", "[", "rootI", "]"}], "=", "rootJ"}]}], "]"}]}], 
     "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
