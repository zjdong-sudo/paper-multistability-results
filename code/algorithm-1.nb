Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Step", " ", "4", " ", "in", " ", "Algorithm", " ", "1."}], " ", 
   "*)"}], "\n", 
  RowBox[{"(*", 
   RowBox[{
   "CheckMatrix", " ", "is", " ", "the", " ", "function", " ", "corresponds", 
    " ", "to", " ", "Step", " ", "4", " ", "in", " ", "Algorithm", " ", "1", 
    " ", "in", " ", "the", " ", 
    RowBox[{"paper", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"CheckMatrix", "[", 
      RowBox[{"a_", ",", "b_", ",", "l_", ",", "s_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
       RowBox[{
        RowBox[{"l1", "=", 
         RowBox[{"Select", "[", 
          RowBox[{
           RowBox[{"Range", "[", "reactions", "]"}], ",", 
           RowBox[{
            RowBox[{"AllTrue", "[", 
             RowBox[{
              RowBox[{"a", "[", 
               RowBox[{"[", 
                RowBox[{"All", ",", "#"}], "]"}], "]"}], ",", 
              RowBox[{
               RowBox[{"#", "==", "0"}], "&"}]}], "]"}], "&"}]}], "]"}]}], 
        ";", 
        RowBox[{"(*", 
         RowBox[{
         "l1", " ", "is", " ", "the", " ", "number", " ", "of", " ", "zero", 
          " ", "columns", " ", "in", " ", 
          RowBox[{"Y", "."}]}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "l1", "]"}], "==", "0"}], ",", 
          RowBox[{"Return", "[", "0", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Length", "[", "l1", "]"}], ">=", 
           RowBox[{"reactions", "-", "2"}]}], ",", 
          RowBox[{"Return", "[", "1", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"linearCombination", "=", 
         RowBox[{"Tuples", "[", 
          RowBox[{"l", ",", "s"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"ans", "=", "0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"comb", "=", 
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"paracomb", "[", 
                RowBox[{"[", "i", "]"}], "]"}], "*", 
               RowBox[{"b", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "s"}], "}"}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"AllTrue", "[", 
              RowBox[{"comb", ",", 
               RowBox[{
                RowBox[{"#", "==", "0"}], "&"}]}], "]"}], ",", 
             RowBox[{"Continue", "[", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"nonZeroPositions", "=", 
            RowBox[{"Position", "[", 
             RowBox[{"comb", ",", 
              RowBox[{"_", "?", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "!=", "0"}], "&"}], ")"}]}]}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"AllTrue", "[", 
              RowBox[{"nonZeroPositions", ",", 
               RowBox[{
                RowBox[{"MemberQ", "[", 
                 RowBox[{"l1", ",", 
                  RowBox[{"#", "[", 
                   RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}]}], "]"}], 
             ",", 
             RowBox[{
              RowBox[{"ans", "=", "1"}], ";", 
              RowBox[{"Break", "[", "]"}]}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"paracomb", ",", "linearCombination"}], "}"}]}], "]"}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ans", "==", "1"}], ",", 
          RowBox[{"Return", "[", "1", "]"}], ",", 
          RowBox[{"Return", "[", "0", "]"}]}], "]"}]}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{"(*", 
    RowBox[{
    "enumerate", " ", "all", " ", "possible", " ", "Y", " ", "matrices", " ", 
     "from", " ", "N", " ", "matrix"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"transformMatrix", "[", "A_", "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"base", ",", "zeroPositions", ",", "replacements"}], "}"}], 
       ",", 
       RowBox[{
        RowBox[{"base", "=", 
         RowBox[{"A", "/.", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"1", "->", "0"}], ",", 
            RowBox[{
             RowBox[{"-", "1"}], "->", "1"}], ",", 
            RowBox[{"0", "->", "0"}]}], "}"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"zeroPositions", "=", 
         RowBox[{"Position", "[", 
          RowBox[{"A", ",", "0"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"replacements", "=", 
         RowBox[{"Tuples", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}], ",", 
           RowBox[{"Length", "[", "zeroPositions", "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"ReplacePart", "[", 
             RowBox[{"base", ",", 
              RowBox[{"Thread", "[", 
               RowBox[{"zeroPositions", "->", "combo"}], "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"combo", ",", "replacements"}], "}"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"AllTrue", "[", 
            RowBox[{
             RowBox[{"Transpose", "[", "#", "]"}], ",", 
             RowBox[{
              RowBox[{"MemberQ", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"0", ",", "1", ",", "2"}], "}"}], ",", 
                RowBox[{"Total", "[", "#", "]"}]}], "]"}], "&"}]}], "]"}], 
           "&"}]}], "]"}]}]}], "]"}]}], ";"}], "\n", 
   StyleBox[
    RowBox[{
     RowBox[{"allk", " ", "=", " ", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Symbol", "[", 
         RowBox[{"\"\<k\>\"", "<>", 
          RowBox[{"ToString", "[", "i", "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "reactions"}], "}"}]}], "]"}]}], ";"}],
    FontSize->14,
    FontWeight->"Plain"], "\n", 
   RowBox[{
    RowBox[{"ans1", "=", 
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Nmatrix", "=", "i"}], ";", "\[IndentingNewLine]", 
        RowBox[{"alphamatrixset", " ", "=", " ", 
         RowBox[{"transformMatrix", "[", "Nmatrix", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"alphamatrix", "=", "j"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"CheckMatrix", "[", 
                RowBox[{"alphamatrix", ",", "Nmatrix", ",", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", 
                   RowBox[{"-", "1"}], ",", "1", ",", 
                   RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", "species"}], 
                "]"}], "==", "0"}], " ", "&&", " ", 
              RowBox[{
               RowBox[{"FindInstance", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Nmatrix", ".", 
                   RowBox[{"Partition", "[", 
                    RowBox[{"allk", ",", "1"}], "]"}]}], "==", 
                  RowBox[{"Table", "[", 
                   RowBox[{
                    RowBox[{"{", "0", "}"}], ",", "species"}], "]"}]}], ",", 
                 "allk", ",", "PositiveReals"}], "]"}], "!=", 
               RowBox[{"{", "}"}]}]}], ",", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"newIndices", "=", 
               RowBox[{"Ordering", "[", 
                RowBox[{
                 RowBox[{"Transpose", "[", "alphamatrix", "]"}], ",", "All", 
                 ",", "LexicographicOrder"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"sortedalphamatrix", "=", 
               RowBox[{"Transpose", "[", 
                RowBox[{
                 RowBox[{"Transpose", "[", "alphamatrix", "]"}], "[", 
                 RowBox[{"[", "newIndices", "]"}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"sortedNmatrix", "=", 
               RowBox[{"Transpose", "[", 
                RowBox[{
                 RowBox[{"Transpose", "[", "Nmatrix", "]"}], "[", 
                 RowBox[{"[", "newIndices", "]"}], "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"{", 
               RowBox[{"sortedalphamatrix", ",", " ", "sortedNmatrix"}], 
               "}"}]}], ",", 
             RowBox[{"{", "}"}]}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "alphamatrixset"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "result"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ans2", "=", 
     RowBox[{"DeleteDuplicates", "[", 
      RowBox[{"DeleteCases", "[", 
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"ans1", ",", "1"}], "]"}], ",", 
        RowBox[{"_", 
         RowBox[{"{", "}"}]}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Length", "@", "ans2"}]}]}]], "Input",
