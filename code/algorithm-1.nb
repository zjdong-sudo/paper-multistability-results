Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Step", " ", "3", " ", "of", " ", "Algorithm", " ", 
    RowBox[{"1", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Delete", " ", "the", " ", "matrices", " ", "having", " ", "the", " ", 
    "same", " ", 
    RowBox[{"form", "."}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"indexlist", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"result", "=", 
     RowBox[{"DeleteCases", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"mat", "=", 
           RowBox[{"Transpose", "[", 
            RowBox[{"difN", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"lists", "=", 
           RowBox[{"DeleteDuplicates", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Sort", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"Position", "[", 
                   RowBox[{"difN", ",", "#"}], "]"}], "[", 
                  RowBox[{"[", 
                   RowBox[{"1", ",", "1"}], "]"}], "]"}], "&"}], "/@", 
                RowBox[{"Transpose", "[", "#", "]"}]}], "]"}], "&"}], "/@", 
             RowBox[{"Permutations", "[", "mat", "]"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Intersection", "[", 
              RowBox[{"indexlist", ",", "lists"}], "]"}], "==", 
             RowBox[{"{", "}"}]}], ",", 
            RowBox[{
             RowBox[{"indexlist", "=", 
              RowBox[{"Union", "[", 
               RowBox[{"indexlist", ",", "lists"}], "]"}]}], ";", "mat"}], 
            ",", "\[IndentingNewLine]", "Nothing"}], "]"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "allN"}], "}"}]}], "]"}], ",", "Nothing"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{"Length", "@", "result"}]}]}]], "Input",
