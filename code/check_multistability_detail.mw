</Group><CodeEditor-ExecGroup view="presentation" hide-input="false" labelreference="L4" drawlabel="true" applyint="true" applyrational="true" display="code"><EC-CodeEditor id="CodeEditRegion0" expanded="true" visible="true" pixel-width="500" pixel-height="200" code-language="text/maple" autofit="true" wrapping="true" show-border="true" code-line-numbers="true">

# 1. \345\256\232\344\271\211\345\244\232\351\241\271\345\274\217\347\216\257
R := PolynomialRing([x1, x2, x3, k1, k2, k3, k4, k5, k6]);

# 2. \345\256\232\344\271\211\347\250\263\346\200\201\346\226\271\347\250\213
F := [-k6*x1*x3 + k3*x2,
      -k4*x2*x3 + k6*x1*x3 - k3*x2 + k1,
      -k6*x1*x3 - k2*x3 + k5*x1 + k1];

N := [];           # \351\235\236\350\264\237\347\272\246\346\235\237
P := [x1, x2, x3, k1, k2, k3, k4, k5, k6];    # \346\255\243\346\200\247\347\272\246\346\235\237
H := [];           # \344\270\215\347\255\211\347\272\246\346\235\237

infolevel[RegularChains] := 1;

# 3. \350\277\220\350\241\214\345\256\236\346\240\271\345\210\206\347\261\273
res := RealRootClassification(F, N, P, H, 6, 3 .. 8, R, output = samples);

# \346\217\220\345\217\226\346\240\267\346\234\254\347\202\271\345\210\227\350\241\250
sample_points := res:-SamplePoints;
num_samples := nops(sample_points);

if num_samples = 0 then
    print(&quot;\346\234\252\346\211\276\345\210\260\344\273\273\344\275\225\346\240\267\346\234\254\347\202\271\343\200\202&quot;);
else
    # \347\224\250\344\272\216\345\255\230\345\202\250\345\244\232\347\250\263\346\200\201\346\240\267\346\234\254\347\202\271\345\217\212\350\257\246\347\273\206\344\277\241\346\201\257\347\232\204\345\210\227\350\241\250
    multistable_samples := [];

    for i from 1 to num_samples do
        sp := sample_points[i];
        
        printf(&quot;\134n========== \346\240\267\346\234\254\347\202\271 %d / %d ==========\134n&quot;, i, num_samples);
        print(sp);
        
        # \345\260\206\345\217\202\346\225\260\344\273\243\345\205\245\357\274\214\345\276\227\345\210\260\346\227\240\345\217\202\346\226\271\347\250\213\347\273\204
        F_num := eval(F, sp);
        
        # \346\261\202\350\247\243\346\211\200\346\234\211\345\256\236\350\247\243
        sols := Isolate(F_num, [x1, x2, x3]);
        
        # \347\255\233\351\200\211\346\255\243\347\250\263\346\200\201 (\346\265\223\345\272\246\345\235\207\345\244\247\344\272\2160)
        pos_sols := select(s -&gt; andmap(eq -&gt; rhs(eq) &gt; 0, s), sols);
        printf(&quot;\346\255\243\351\251\273\347\202\271\346\200\273\346\225\260: %d\134n&quot;, nops(pos_sols));
        
        # \345\255\230\345\202\250\346\211\200\346\234\211\346\255\243\347\250\263\346\200\201\347\232\204\350\257\246\347\273\206\344\277\241\346\201\257
        steady_states_info := [];
        for sol in pos_sols do
            sub_list := [op(sp), op(sol)];
            # \350\256\241\347\256\227\351\233\205\345\217\257\346\257\224\345\271\266\346\225\260\345\200\274\345\214\226
            J_num := eval(Jacobian(F, [x1, x2, x3]), sub_list);
            J_val := evalf(J_num);
            try
                evals := Eigenvalues(J_val);
                # \345\210\244\346\226\255\346\211\200\346\234\211\347\211\271\345\276\201\345\200\274\345\256\236\351\203\250 &lt; 0\357\274\210\350\200\203\350\231\221\346\225\260\345\200\274\345\256\271\345\267\256\357\274\211
                # \346\230\276\345\274\217\350\275\254\346\215\242\344\270\272\345\270\203\345\260\224\347\261\273\345\236\213\345\255\230\345\202\250
                is_stable := evalb(andmap(e -&gt; Re(e) &lt; -1e-9, convert(evals, list)));
                steady_states_info := [op(steady_states_info), [sol, evals, is_stable]];
            catch:
                printf(&quot;\350\256\241\347\256\227\347\211\271\345\276\201\345\200\274\346\227\266\345\207\272\351\224\231\357\274\214\350\267\263\350\277\207\350\257\245\347\202\271\343\200\202\134n&quot;);
            end try;
        end do;
        
        # \347\273\237\350\256\241\347\250\263\345\256\232\346\255\243\351\251\273\347\202\271\344\270\252\346\225\260 (\346\230\276\345\274\217\345\210\244\346\226\255 = true)
        stable_count := nops(select(st -&gt; evalb(st[3] = true), steady_states_info));
        printf(&quot;\347\250\263\345\256\232\346\255\243\351\251\273\347\202\271\344\270\252\346\225\260: %d\134n&quot;, stable_count);
        
        # \350\276\223\345\207\272\346\257\217\344\270\252\346\255\243\347\250\263\346\200\201\347\232\204\350\257\246\347\273\206\344\277\241\346\201\257
        if nops(steady_states_info) &gt; 0 then
            printf(&quot;\346\211\200\346\234\211\346\255\243\351\251\273\347\202\271\350\257\246\346\203\205:\134n&quot;);
            for j from 1 to nops(steady_states_info) do
                st := steady_states_info[j];
                printf(&quot;  \351\251\273\347\202\271 %d:\134n&quot;, j);
                printf(&quot;    \346\265\223\345\272\246\345\200\274: &quot;);
                print(st[1]);
                printf(&quot;    \347\211\271\345\276\201\345\200\274: &quot;);
                print(st[2]);
                if st[3] = true then
                    printf(&quot;    \347\250\263\345\256\232\346\200\247: \347\250\263\345\256\232\134n&quot;);
                else
                    printf(&quot;    \347\250\263\345\256\232\346\200\247: \344\270\215\347\250\263\345\256\232\134n&quot;);
                end if;
            end do;
        end if;
        
        # \345\244\232\347\250\263\346\200\201\345\210\244\345\256\232\344\270\216\344\277\241\346\201\257\345\255\230\345\202\250
        if stable_count &gt;= 2 then
            printf(&quot;&gt;&gt;&gt; \350\257\245\346\240\267\346\234\254\347\202\271\345\257\271\345\272\224\347\232\204\345\217\202\346\225\260\346\235\241\344\273\266\344\270\213\357\274\214\347\275\221\347\273\234\345\205\267\346\234\211\345\244\232\347\250\263\346\200\201&lt;&lt;&lt;\134n&quot;);
            multistable_samples := [op(multistable_samples), [sp, steady_states_info]];
        else
            printf(&quot;\350\257\245\346\240\267\346\234\254\347\202\271\346\227\240\345\244\232\347\250\263\346\200\201\343\200\202\134n&quot;);
        end if;
    end do;
    
    # \346\261\207\346\200\273\350\276\223\345\207\272
    if nops(multistable_samples) &gt; 0 then
        printf(&quot;\134n========== \345\244\232\347\250\263\346\200\201\346\240\267\346\234\254\347\202\271\346\261\207\346\200\273 ==========\134n&quot;);
        for k from 1 to nops(multistable_samples) do
            entry := multistable_samples[k];
            printf(&quot;\134n\346\240\267\346\234\254\346\261\207\346\200\273\351\241\271 %d:\134n&quot;, k);
            print(entry[1]);
            # \350\256\241\347\256\227\350\257\245\351\241\271\344\270\255\347\232\204\347\250\263\345\256\232\347\202\271\346\225\260
            cur_stable := nops(select(st -&gt; evalb(st[3] = true), entry[2]));
            printf(&quot;  \347\250\263\345\256\232\351\251\273\347\202\271\344\270\252\346\225\260: %d\134n&quot;, cur_stable);
        end do;
    else
        printf(&quot;\134n\345\234\250\346\211\200\346\234\211\346\240\267\346\234\254\347\202\271\344\270\255\346\234\252\345\217\221\347\216\260\345\244\232\347\250\263\346\200\201\347\216\260\350\261\241\343\200\202\134n&quot;);
    end if;
end if;</EC-CodeEditor>
