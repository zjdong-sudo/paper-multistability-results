# 1. \350\267\257\345\276\204\350\256\276\347\275\256
T := Import(&quot;D:/multistability/odesystem.csv&quot;, output = Matrix):
C := Import(&quot;D:/multistability/candidate_indices_2.csv&quot;, output = Matrix): 
final_report := &quot;D:/multistability/check_multistability_2.txt&quot;:

# 2. \347\216\257\345\242\203\345\210\235\345\247\213\345\214\226
vars := [x1, x2, x3]:
params := [k1, k2, k3, k4, k5, k6]:
R := PolynomialRing([op(vars), op(params)]):

num_candidates := LinearAlgebra:-RowDimension(C):
global_summary_list := []: 

# \346\230\276\345\274\217\345\234\250\347\273\210\347\253\257\346\211\223\345\215\260\345\274\200\345\247\213\344\277\241\346\201\257
printf(&quot;&gt;&gt;&gt; \345\205\261\351\234\200\345\244\204\347\220\206 %d \344\270\252\345\200\231\351\200\211\347\275\221\347\273\234 &lt;&lt;&lt;\134n&quot;, num_candidates);


# \345\210\235\345\247\213\345\214\226/\346\270\205\347\251\272\346\226\207\344\273\266
fd := fopen(final_report, WRITE):
fclose(fd):

for j from 1 to num_candidates do
    raw_val := C[j, 1]:
    net_idx := `if`(type(raw_val, string), parse(raw_val), raw_val):
    
    # \347\273\210\347\253\257\345\256\236\346\227\266\350\277\233\345\272\246
    printf(&quot;\346\255\243\345\234\250\345\244\204\347\220\206\347\254\254 %d/%d \344\270\252\347\275\221\347\273\234 (\347\264\242\345\274\225: %a)... &quot;, j, num_candidates, net_idx);
    
    f1 := parse(T[net_idx, 1]):
    f2 := parse(T[net_idx, 2]):
    f3 := parse(T[net_idx, 3]):
    F := [f1, f2, f3]:
    
    total_samples_found := 0:
    total_pos_sols_found := 0:
    total_stable_sols_found := 0:
    max_stable_per_sample := 0:

    try
        
        res := RealRootClassification(F, [], [op(vars), op(params)], [], 6, 3..8, R, output = samples):
        sample_points := res:-SamplePoints:
        total_samples_found := nops(sample_points):

        if total_samples_found &gt; 0 then
            # \345\206\231\345\205\245\346\226\207\344\273\266\350\257\246\346\203\205
            appendto(final_report):
            printf(&quot;\134n%s\134n&quot;, Repeat(&quot;=&quot;, 60)):
            printf(&quot;\347\275\221\347\273\234\347\264\242\345\274\225: %a | \346\240\267\346\234\254\347\202\271\346\225\260: %d\134n&quot;, net_idx, total_samples_found):
            printf(&quot;%s\134n&quot;, Repeat(&quot;=&quot;, 60)):

            for k from 1 to total_samples_found do
                sp := sample_points[k]:
                F_num := eval(F, sp):
                sols := Isolate(F_num, vars):
                pos_sols := select(s -&gt; andmap(eq -&gt; rhs(eq) &gt; 0, s), sols):
                
                total_pos_sols_found := total_pos_sols_found + nops(pos_sols):
                sp_stable_count := 0:

                printf(&quot;\134n  [\346\240\267\346\234\254\347\202\271 %d]: %a\134n&quot;, k, sp):
                
                for sol in pos_sols do
                    sub_list := [op(sp), op(sol)]:
                    J_num := eval(VectorCalculus:-Jacobian(F, vars), sub_list):
                    evals := Eigenvalues(evalf(J_num)):
                    is_stable := evalb(andmap(e -&gt; Re(e) &lt; -1e-9, convert(evals, list))):
                    
                    if is_stable then 
                        sp_stable_count := sp_stable_count + 1: 
                        total_stable_sols_found := total_stable_sols_found + 1:
                    fi:
                    
                    printf(&quot;    - \346\265\223\345\272\246: %a\134n&quot;, sol):
                    printf(&quot;      \347\211\271\345\276\201\345\200\274: %a\134n&quot;, evals):
                    printf(&quot;      \347\212\266\346\200\201: %s\134n&quot;, `if`(is_stable, &quot;\347\250\263\345\256\232&quot;, &quot;\344\270\215\347\250\263\345\256\232&quot;)):
                od:
                printf(&quot;  \345\260\217\347\273\223: \350\257\245\347\202\271\346\255\243\351\251\273\347\202\271%d, \347\250\263\345\256\232 %d\134n&quot;, nops(pos_sols), sp_stable_count):
                max_stable_per_sample := max(max_stable_per_sample, sp_stable_count):
            od:
            is_multistable := max_stable_per_sample &gt;= 2:
            # \345\210\207\345\233\236\347\273\210\347\253\257\346\230\276\347\244\272\346\210\220\345\212\237
            writeto(terminal):
            printf(&quot;\345\256\214\346\210\220 (\345\215\225\347\202\271\346\234\200\345\244\247\347\250\263\345\256\232: %d, \345\244\232\347\250\263\346\200\201: %s)\134n&quot;, max_stable_per_sample, `if`(is_multistable, &quot;\346\230\257&quot;, &quot;\345\220\246&quot;));
        else
            writeto(terminal):
            printf(&quot;\350\267\263\350\277\207 (\346\227\240\346\240\267\346\234\254\347\202\271)\134n&quot;);
        fi:
        global_summary_list := [op(global_summary_list), [net_idx, total_samples_found, total_pos_sols_found, max_stable_per_sample, is_multistable]]:
        
    catch:
