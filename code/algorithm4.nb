Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"batchSize7", "=", "10000"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"totalV", "=", 
   RowBox[{"Length", "[", "validStep6", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"numBatches7", "=", 
    RowBox[{"Ceiling", "[", 
     RowBox[{"totalV", "/", "batchSize7"}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{
    "\"\<Step 7 \:5f00\:59cb\:ff0c\:5171 \>\"", ",", "totalV", ",", 
     "\"\< \:4e2a\:7f51\:7edc...\>\""}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"start", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"b", "-", "1"}], ")"}], "*", "batchSize7"}], "+", "1"}]}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"end", "=", 
       RowBox[{"Min", "[", 
        RowBox[{
         RowBox[{"b", "*", "batchSize7"}], ",", "totalV"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"batchResult7", "=", 
       RowBox[{"ParallelTable", "[", 
        RowBox[{
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"idx", ",", "alphat", ",", "capitalN", ",", "GBset"}], 
            "}"}], ",", 
           RowBox[{
            RowBox[{"idx", "=", 
             RowBox[{"validStep6", "[", 
              RowBox[{"[", 
               RowBox[{"j", ",", "1"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"alphat", "=", 
             RowBox[{"validStep6", "[", 
              RowBox[{"[", 
               RowBox[{"j", ",", "2"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"capitalN", "=", 
             RowBox[{"validStep6", "[", 
              RowBox[{"[", 
               RowBox[{"j", ",", "3"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"(*", 
             RowBox[{
             "\:5bf9", " ", "6", " ", 
              "\:79cd\:7f6e\:6362\:5206\:522b\:8ba1\:7b97", " ", "GB"}], 
             "*)"}], 
            RowBox[{"GBset", "=", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"Sort", "[", 
                RowBox[{"GroebnerBasis", "[", 
                 RowBox[{
                  RowBox[{"capitalN", ".", 
                   RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"v", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], "*", 
                    RowBox[{"Inner", "[", 
                    RowBox[{"Power", ",", 
                    RowBox[{"listvars", "[", 
                    RowBox[{"[", "p", "]"}], "]"}], ",", 
                    RowBox[{"alphat", "[", 
                    RowBox[{"[", "k", "]"}], "]"}], ",", "Times"}], "]"}]}], 
                    ",", 
                    RowBox[{"{", 
                    RowBox[{"k", ",", "1", ",", "reactions"}], "}"}]}], 
                    "]"}]}], ",", "xs", ",", 
                  RowBox[{"CoefficientDomain", "->", "RationalFunctions"}], 
                  ",", 
                  RowBox[{
                  "MonomialOrder", "->", "DegreeReverseLexicographic"}]}], 
                 "]"}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"p", ",", "1", ",", 
                 RowBox[{"Length", "[", "listvars", "]"}]}], "}"}]}], "]"}]}],
             ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"idx", ",", "alphat", ",", "capitalN", ",", 
              RowBox[{"DeleteDuplicates", "[", "GBset", "]"}]}], "}"}]}]}], 
          "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "start", ",", "end"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Export", "[", 
       RowBox[{
        RowBox[{"path", "<>", "\"\<step7_batch_\>\"", "<>", 
         RowBox[{"ToString", "[", "b", "]"}], "<>", "\"\<.mx\>\""}], ",", 
        "batchResult7"}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Clear", "[", "batchResult7", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<Step 7: \:5df2\:5b8c\:6210\:6279\:6b21 \>\"", ",", "b", ",", 
        "\"\< / \>\"", ",", "numBatches7"}], "]"}], ";"}], ",", 
     RowBox[{"{", 
      RowBox[{"b", ",", "1", ",", "numBatches7"}], "}"}]}], "]"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
